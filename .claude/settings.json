{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv:*)",
      "Bash(uv run:*)",
      "Bash(make:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(finops:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(curl:*)",
      "Bash(jq:*)",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./samples/**)",
      "Edit(./docs/**)",
      "Edit(./.github/**)",
      "Edit(prompts.md)",
      "Edit(BITACORA.md)",
      "Edit(README.md)",
      "Edit(Makefile)",
      "Edit(pyproject.toml)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(aws ec2 terminate-instances:*)",
      "Bash(aws ec2 delete-volume:*)",
      "Bash(aws rds delete-db-instance:*)",
      "Bash(aws s3 rb:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(kubectl delete:*)",
      "Edit(./.env)",
      "Edit(./data/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/safety_gate.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/prompt_logger.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/elapsed_time.sh" }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/status_line.sh"
  },
  "model": "claude-opus-4-7",
  "env": {
    "FINOPS_LOG_PROMPTS": "true",
    "FINOPS_REPORT_ELAPSED": "true"
  }
}
