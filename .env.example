# Copy to .env and fill in. .env is gitignored.

# ==============================
# Anthropic — sub-agent intelligence layer
# ==============================
# When unset, AnalyzerAgent and RemediatorAgent fall back to deterministic
# templates with identical interfaces. The system remains fully demoable.
ANTHROPIC_API_KEY=

# Models (defaults are production-grade; override only for cost experiments)
ANTHROPIC_ORCHESTRATOR_MODEL=claude-opus-4-7
ANTHROPIC_WORKER_MODEL=claude-haiku-4-5

# ==============================
# Webhook simulator
# ==============================
# Where /alerts/webhook-test POSTs. localhost echo is fine for demo.
WEBHOOK_URL=http://localhost:8765/alert-sink

# ==============================
# Risk thresholds
# ==============================
# overall_risk above this triggers webhook + dashboard banner
RISK_THRESHOLD=70

# Severity weights (used by detection.scoring)
SEVERITY_WEIGHT_LOW=1
SEVERITY_WEIGHT_MEDIUM=3
SEVERITY_WEIGHT_HIGH=8

# ==============================
# Database
# ==============================
DATABASE_URL=sqlite:///./data/finops.db

# ==============================
# Server
# ==============================
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501
MCP_HTTP_PORT=8765
